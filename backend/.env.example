# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/openlesson?retryWrites=true&w=majority

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# SendGrid Email
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Google API (for Gemini AI)
GOOGLE_API_KEY=your-google-api-key

# Zoom
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# Server
PORT=5000
NODE_ENV=development

# PayHere Payment Gateway
PAYHERE_MERCHANT_ID=your-payhere-merchant-id
PAYHERE_MERCHANT_SECRET=your-payhere-merchant-secret
PAYHERE_ENV=sandbox
PAYHERE_CHECKOUT_URL=https://sandbox.payhere.lk/pay/checkout
PAYHERE_NOTIFY_URL=https://your-backend-url.onrender.com/api/payments/payhere/notify
BACKEND_PUBLIC_URL=https://your-backend-url.onrender.com
API_PUBLIC_URL=https://your-backend-url.onrender.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email Configuration
EMAIL_FROM=noreply@openlesson.com
ADMIN_EMAIL=support@openlesson.com
ADMIN_PASSWORD=your-admin-password-min-8-chars
